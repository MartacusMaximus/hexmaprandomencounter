  m_Script: {fileID: 11500000, guid: 364c2b772391e46dba637935c558b9b2, type: 3}
  m_Name: Elephant
  m_EditorClassIdentifier: Assembly-CSharp::MythSO
  pageNumber: 163
  mythName: Elephant
  omens:
  - '1. With thunderous steps, the Elephant

    Knight parades past with armoured

    soldiers.
    She marches toward the Seat of

    Power to receive a hero''s welcome.'
  - '2. Excited children bicker over which of the

    Elephant Knight''s deeds were
    the

    greatest (see opposite).'
  - '3. A cruel hunter watches from the shadows,

    quietly alerting the Company
    and asking

    if they have seen the Elephant. He is

    hunting it for sport.'
  - '4. The Elephant lies dead, the Elephant

    Knight screaming in anger, running
    into

    the distance. The hunter lurks, waiting

    for a safe moment to claim
    his trophy.'
  - '5. In a muddy pit, the Elephant Knight

    slathers herself in wet clay, shouting
    to

    the sky in a language you cannot speak.

    She fights off any attempt
    to stop her,

    leaving when completely caked in clay.'
  - '6. A monstrous clay elephant smashes at

    trees, trumpets at the sky. Heavy
    rain

    begins to fall, washing the creature away

    into the damp earth.'
  verse: 'Booming march and children'' s cheer

    A hunter ushers death a''near'
  castEntries:
  - name: The Elephant, Balihanthor
    statBlock: 'VIG 18, CLA 5, SPI 5, 6 GD

      A3 (tough hide, mail)'
    notes: 'Gore (d10) and trample (2d10)

      Only feels safe with the Elephant
      Knight.'
  - name: The Elephant Knight, Castine
    statBlock: 'VIG 16, CLA 9, SPI 13, 8 GD

      A2 (blue-embroidered gambeson,
      helm)'
    notes: 'Hooked greatsword (2d10 slow)

      Travel-weary. Wants to retire in
      comfort.'
  - name: Cruel Hunter, Berach
    statBlock: 'VIG 14, CLA 16, SPI 6, 6 GD

      Crossbow (2d8 slow), shadowy cloak,'
    notes: 'countless pots of animal bait and repellent

      Can Smite when shooting
      prey.'
  flavorTable:
    title: DEEDS OF THE ELEPHANT KNIGHT
    columns:
    - header: Action
      values:
      - Defeated the...
      - Restored the...
      - Mastered the...
      - Exposed the...
      - Sated the...
      - Beheaded the...
    - header: Target
      values:
      - Iron Crocodile
      - Invisible Wolf
      - Faerie King
      - Blood Heron
      - Labyrinth Beast
      - Mirror Ghost
  visibleByDefault: 0
  visibleMarkerPrefab: {fileID: 0}
