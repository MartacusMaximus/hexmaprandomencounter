%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: cc4fbe46da3be4b4ea248099971d9be8, type: 3}
  m_Name: BiomePrefabSO
  m_EditorClassIdentifier: Assembly-CSharp::BiomePrefabSO
  entries:
  - biome: 0
    visualPrefab: {fileID: 6967347023646858695, guid: d39b77f0babb74704b3bf222e0803eb2, type: 3}
    locationTexts:
    - 'Grinder: Soil gives way to immense cogs and wheels, turning'
    - 'Ore Field: A jumble of immense boulders and slag'
    - 'Canyonlands: The land here has been worn to winding gorges'
    - 'Rust River: A deep, winding river is dark red with decades of rust'
    - 'Waterfall: You find a massive waterfall, vertical, crescent shaped'
    - 'Elder Tree: Some pines have survived to immense age'
    - 'Cliffside Way: A precarious stone path on a winding cliff side'
    - 'Canisters: Huge tanks of pressurized gas lying around'
    - 'Haven: A bunker-like building, proof against the machines'
    - 'Control Platform: You find a round disc, levers and controls nearby'
    eventTexts:
    - 'Meshing of Teeth: 2D4 Clockworks emerge from the dirt, enraged'
    - '2. Madman: A cannibal madman who abides no visitors'
    - "3. Hasgar\u2019s Salvage: Cruel giants labor to move an immense wheel"
    - '4. Crumble: Reddish rocks slide down the mountain!'
    - '5. Cliffspear: One cunning cliff giant hunts the heroes'
    - '6. Lightning Jump: A device using lightning to travel, unstable, weird'
    - '7. Hybrid: A dire wolf, enmeshed with metal and gears, prowls'
    - '8. Lost: Escaped prisoners of Hasgar giants wander aimlessly'
    - '9. Lying Around: A broken cart with equipment and treasure'
    - '10. Researcher: A white-bearded dwarf is studying the clockworks'
  - biome: 1
    visualPrefab: {fileID: 6967347023646858695, guid: f67d58d69bf1a41099bd7f005465ef6d, type: 3}
    locationTexts:
    - 'Fae Glade: Odd magic makes for circles and confusion... no way out?'
    - 'Deep Tangle: The woods here are so thick, they are barely passable'
    - 'Rootrock: A mixture of massive roots and square stones'
    - 'Towering Pines: Flat ground with sparse trees... an unnerving scene'
    - 'Crumbled Ruins: The curved pillars and cobble stairs of elven temples'
    - 'Elven Road: A smooth-stone causeway, vulnerable from all sides'
    - 'Boulder Glen: A colossal granite boulder dominates a clearing'
    - 'Hillock: A small, pleasant rise of grassy soil and good views'
    - 'Aspen Grove: Magic whispers in golden leaves... forest song'
    - 'Mossrock Spring: Pristine water bubbles up from a frosty stone fissure'
    eventTexts:
    - 'Ogre Incursion: A group of 2D4 Ogre warriors is wreaking havoc'
    - 'Dragonkin Roost: You stumble on a large group of 4d12 dragonlings'
    - 'A Mad Chopper: The fae have driven a woodsman mad for blood'
    - 'Duel: Two elven knights square off, set to settle some dire feud'
    - 'Patrol: Elf spearmen walk, securing the road, dour faces'
    - 'Bleeding Tree: An elder oak is corrupted with black ichor from below'
    - 'Trebuchet: A pitched battle with armored ogres and elf artillery'
    - 'Sunlight Lance: You find an heirloom lance, perched on a ritual stone'
    - 'King''s Day Column: a host of jousters are heading to King''s Field'
    - 'Faerie Flow: You encounter a cloud of faerie folk, drifting along'
  - biome: 2
    visualPrefab: {fileID: 6967347023646858695, guid: 8574321a7304d4579bbe6b7fa5bf653b, type: 3}
    locationTexts:
    - '1. Wicker Traps: Huge woven stick-traps ambush our heroes'
    - "2. Sinking Muck: What\u2019s worse? Sinking muck or attacking frogs?"
    - '3. Marrowwood: Trees of fish bone, brambles of antler... hell'
    - '4. Trash Field: A landscape of detritus discarded by the frog empire'
    - '5. Hanging Garden: A weird scene of horticulture... mostly edible moss'
    - '6. Cobbles: The roads of frog folk are soft, but workable'
    - '7. Frog Village: You find a collection of thatch huts and long houses'
    - '8. Stilt Huts: These fishing huts stand 10 feet above the swamp'
    - '9. Temple: A stepped pyramid of mushy stone... chanting within'
    - '10. Ziggurat: Masterful, complex, immense pyramids of stone and alloy'
    eventTexts:
    - '1. Hunted: Our heroes are relentlessly pursued by frog killers'
    - 'Border Guard: A threesome of frogs in heavy armor stop the travelers'
    - '3. Priests of Exodur: Robed frogs worship the stars, seeking sacrifices'
    - '4. Swarm: You stumble into a massive cloud of biting insects'
    - '5. For the Emperor: Champions parade toward Gulglac'
    - '6. Heads and Hearts: A day of sacrifice... heads and hearts are taken'
    - '7. The Games: Massive crowds gather to watch amphibians play ball'
    - 'Tadpoling: The greatest day in frogdom is unfolding... eggs everywhere'
    - 'An Invitation: A strange frog, a scholar, invites heroes to the palace'
    - '10. A Day for Glug: Frogs set down their arms, celebrating with drink'
  - biome: 3
    visualPrefab: {fileID: 6967347023646858695, guid: 2c825919b8ce64d11a0525c604589a26, type: 3}
    locationTexts:
    - '1. Bleeding Spur: The huge root of a bleeding tree, breaking the bedrock'
    - '2. Sop Gulch: This area is thick with black mud and rotten trees'
    - '3. Endless Deadfall: Many trees have fallen here, forming a maze'
    - '4. Trap Network: The trees are rigged with snares and trip wires'
    - '5. Hollows: Deep ravines hide shadowy glades that never see sun'
    - '6. Maze of Pools: Ponds and deep lakes dot the area'
    - '7. Grove Circle: A clearing, ringed by identical pines, an odd scene'
    - '8. Mud Meadow: This wide, clear area has soft peat as its floor'
    - '9. Tower Tree: One titanic oak shades all below, trunk as wide as a house'
    - '10. Goodly Hut: You find a small, welcoming hut in the gloom'
    eventTexts:
    - '1. Stalac Stone Summoned: A cruel Stalac Stone rises from the mud'
    - 'Hungry Goblins: A huge pack of rat-goblins swarm the woods'
    - '3. Mushrooms on Fire: A fire has broken out, fungus folk are everywhere'
    - '4. Blighted: The black water is congealing, taking on a higher form'
    - '5. Chained Feeders: Wretched blood-drinkers chained up, left to rot'
    - '6. Shaman Seance: A goblin wizard communes with ancient ghosts'
    - '7. Bats! Bats!: More bats than one would care to imagine... feeding'
    - "8. The Sink: Suddenly, the ground sags and drops ten feet! What\u2019s below?"
    - 'A Lost Lantern: A Nightstalker, confused and almost dead, wanders'
    - '10. Pilgrim Ghost: A specter wanders, heading for a long-ruined abbey'
  - biome: 4
    visualPrefab: {fileID: 6967347023646858695, guid: 1a7434346dd344d27a3fdf13c4d6ac60, type: 3}
